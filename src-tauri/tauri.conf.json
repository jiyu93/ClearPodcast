{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClearPodcast",
  "version": "0.1.0",
  "identifier": "com.clearpodcast.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ClearPodcast",
        "width": 960,
        "height": 640,
        "minWidth": 760,
        "minHeight": 540
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
