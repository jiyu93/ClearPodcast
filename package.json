{
  "name": "clearpodcast",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "check:audio-playback": "node --experimental-strip-types scripts/check-audio-playback-timing.mjs",
    "check:audio-waveform": "node --experimental-strip-types scripts/check-audio-waveform-silence.mjs",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "check": "tsc --noEmit",
    "package:stage:macos-cpu": "node scripts/stage-macos-cpu-resources.mjs",
    "package:macos-cpu": "node scripts/build-macos-cpu-portable.mjs",
    "licenses:windows-x64": "node scripts/generate-third-party-notices.mjs windows-x64",
    "package:stage:windows-x64": "node scripts/stage-windows-x64-resources.mjs",
    "package:windows-x64": "node scripts/build-windows-x64-portable.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.9.0",
    "vite": "^7.0.0"
  }
}
